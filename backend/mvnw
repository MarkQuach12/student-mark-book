#!/bin/sh
# Maven Wrapper script for Unix
# Downloads Maven if not present and runs it

set -e

MAVEN_HOME="${HOME}/.m2/wrapper/dists/apache-maven-3.9.9"
MAVEN_URL="https://repo.maven.apache.org/maven2/org/apache/maven/apache-maven/3.9.9/apache-maven-3.9.9-bin.zip"

if [ ! -d "$MAVEN_HOME" ]; then
    echo "Downloading Maven 3.9.9..."
    mkdir -p "$MAVEN_HOME"
    curl -fsSL "$MAVEN_URL" -o "/tmp/maven.zip"
    unzip -qo "/tmp/maven.zip" -d "${HOME}/.m2/wrapper/dists"
    rm "/tmp/maven.zip"
fi

exec "$MAVEN_HOME/bin/mvn" "$@"
